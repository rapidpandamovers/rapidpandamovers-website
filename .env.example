# Site URL override (for local dev Lighthouse testing; omit in production)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps API Key (for scripts/update_drive_times.py)
GOOGLE_MAPS_API_KEY=your-api-key-here

# Google Maps Embed API Key (optional - embed works without it but with API key gives better features)
# Get a key at https://console.cloud.google.com/apis/credentials
# Enable "Maps Embed API" in the Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-embed-api-key-here

# SMTP Configuration for Email Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@rapidpandamovers.com

# Email address to receive form submissions
CONTACT_EMAIL=info@rapidpandamovers.com

# Review APIs (for scripts/fetch_reviews.py)
# Google Places API - Enable "Places API" in Google Cloud Console
# Uses same key as GOOGLE_MAPS_API_KEY if not set separately
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Google Place ID (optional - speeds up lookups)
# Find yours at: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=

# Yelp Fusion API - Get key at https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your-yelp-fusion-api-key

# Yelp Business ID/Alias (optional)
YELP_BUSINESS_ID=rapid-panda-movers-miami

# Trustpilot API - Get key at https://developers.trustpilot.com/ (requires business account)
TRUSTPILOT_API_KEY=your-trustpilot-api-key
TRUSTPILOT_BUSINESS_UNIT_ID=

# Better Business Bureau (BBB) API - Get key at https://developer.bbb.org/
BBB_API_KEY=your-bbb-api-key
BBB_BUSINESS_ID=

# Facebook Graph API - Get token at https://developers.facebook.com/
# Requires a Facebook App and Page access token with pages_read_user_content permission
FACEBOOK_ACCESS_TOKEN=your-facebook-page-access-token
FACEBOOK_PAGE_ID=your-facebook-page-id

# Review Scraper URLs (for scripts/scrape_reviews.py - no API keys needed)
# Direct URLs to your business review pages
YELP_URL=https://www.yelp.com/biz/rapid-panda-movers-miami
TRUSTPILOT_URL=https://www.trustpilot.com/review/rapidpandamovers.com
BBB_URL=https://www.bbb.org/us/fl/miami/profile/moving-companies/rapid-panda-movers
FACEBOOK_URL=https://www.facebook.com/rapidpandamovers/reviews
CONSUMERAFFAIRS_URL=https://www.consumeraffairs.com/movers/rapid-panda-movers.html
HIREAHELPER_URL=https://www.hireahelper.com/moving-companies/rapid-panda-movers/
ANGI_URL=https://www.angi.com/companylist/us/fl/miami/rapid-panda-movers-reviews.htm
THUMBTACK_URL=https://www.thumbtack.com/fl/miami/movers/rapid-panda-movers/
MOVERSCOM_URL=https://www.movers.com/moving-company/rapid-panda-movers.html

# Cloudflare Turnstile
# For development/testing, use these test keys (always passes):
#   Site key: 1x00000000000000000000AA
#   Secret key: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
